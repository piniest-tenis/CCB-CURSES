# Daggerheart Character Platform — Environment Variables
#
# Copy this file to .env (repo root) for local development.
# NEVER commit .env or any file containing real credentials.
#
# ─── Variable Resolution Order ────────────────────────────────────────────────
# 1. Already-set shell / CI environment variables  (highest priority)
# 2. Repo-root .env
# 3. frontend/.env.local  (Next.js public vars)
# 4. ingestion/.env.ingestion  (ingestion-specific overrides)
#
# ─── Sensitive vs. Non-sensitive ─────────────────────────────────────────────
# • AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — HIGHLY SENSITIVE.
#   Treat these like passwords.  Rotate immediately if ever committed or leaked.
#   Use IAM roles in Lambda/CI — never deploy with static keys in production.
# • NEXT_PUBLIC_* vars are embedded in the browser bundle.
#   They are not secret, but exposing real endpoint URLs is bad hygiene.

# ─── AWS Credentials (Local Dev / Deploy Scripts Only) ───────────────────────
# In Lambda/CI these come from the attached IAM role — leave blank there.
# For local dev: set these to an IAM user that has the minimum required perms.
# Generate a new key pair at: AWS Console → IAM → Users → Security credentials
#
# ⚠ ROTATE IMMEDIATELY if you see REDACTED_AWS_KEY_ID anywhere — it was leaked.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-2
# AWS_DEFAULT_REGION is an alias used by some older scripts
AWS_DEFAULT_REGION=us-east-2

# ─── Frontend Deploy (deploy-frontend.bat / frontend/scripts/deploy-s3.mjs) ──
# S3 bucket that serves the static Next.js export
FRONTEND_S3_BUCKET=daggerheart-frontend-dev-XXXXXXXXXXXX
# CloudFront distribution in front of that bucket (for cache invalidation)
CF_DISTRIBUTION_ID=XXXXXXXXXXXXX

# ─── Frontend (Next.js — NEXT_PUBLIC_* embedded at build time) ───────────────

# Base URL of the deployed API Gateway HTTP API
# Example: https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com/dev
NEXT_PUBLIC_API_URL=http://localhost:3001

# Cognito User Pool ID  (format: us-east-2_xxxxxxxxx)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
NEXT_PUBLIC_COGNITO_REGION=us-east-2

# Cognito App Client ID (no client secret — SPA PKCE client)
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Issuer URL (used for JWT verification)
NEXT_PUBLIC_COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_XXXXXXXXX

# CloudFront CDN domain for media assets
NEXT_PUBLIC_CDN_DOMAIN=dxxxxxxxxxxxxxx.cloudfront.net
NEXT_PUBLIC_CDN_URL=https://dxxxxxxxxxxxxxx.cloudfront.net

# Build/deploy stage
NEXT_PUBLIC_STAGE=dev

# ─── CMS (cms/src/lib/auth.ts, cms/src/lib/api.ts) ───────────────────────────
# CMS-specific Cognito client (Google SSO PKCE client — separate from the player app)
NEXT_PUBLIC_COGNITO_CMS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_HOSTED_DOMAIN=daggerheart-dev.auth.us-east-2.amazoncognito.com

# ─── Backend Lambda (injected by CDK at deploy time — not needed locally) ────
# These variables are set on each Lambda function by the CDK stack.
# They are listed here only for documentation; set them via CDK env or SSM.

# HMAC secret for signing share tokens. Must be a long random string.
# Generate with: openssl rand -hex 32
SHARE_TOKEN_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public frontend URL used when constructing share links
FRONTEND_URL=https://app.daggerheart.example.com

# DynamoDB table names (injected by CDK — match the CDK stack names)
# CHARACTERS_TABLE=daggerheart-characters-dev
# CLASSES_TABLE=daggerheart-classes-dev
# GAMEDATA_TABLE=daggerheart-gamedata-dev
# DOMAINCARDS_TABLE=daggerheart-domaincards-dev
# MEDIA_TABLE=daggerheart-media-dev
# USERS_TABLE=daggerheart-users-dev

# S3 media bucket (injected by CDK)
# S3_MEDIA_BUCKET=daggerheart-media-dev-XXXXXXXXXXXX

# CloudFront CDN domain for media URLs (injected by CDK)
# CDN_DOMAIN=dxxxxxxxxxxxxxx.cloudfront.net

# ─── Ingestion Pipeline ───────────────────────────────────────────────────────
# AWS creds — inherited from root .env above; re-declare here only to override.
# DYNAMODB_REGION=us-east-2

# Target DynamoDB tables for ingestion (can override per-run with CLI flags)
# TABLE_CLASSES=daggerheart-classes-dev
# TABLE_GAME_DATA=daggerheart-gamedata-dev
# TABLE_DOMAIN_CARDS=daggerheart-domaincards-dev
# INGEST_CLASSES_TABLE=daggerheart-classes-dev
# INGEST_GAMEDATA_TABLE=daggerheart-gamedata-dev
# INGEST_DOMAINCARDS_TABLE=daggerheart-domaincards-dev

# ─── CDK Bootstrap ────────────────────────────────────────────────────────────
# AWS account and region used for CDK deployments.
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-2

# Deployment stage: dev | staging | prod
STAGE=dev
