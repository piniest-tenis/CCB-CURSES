# Daggerheart Character Platform — Environment Variables
#
# Copy this file to .env.local for local development.
# Never commit .env.local to source control.
#
# All NEXT_PUBLIC_* vars are embedded into the browser bundle at build time.
# All other vars are server-side only (used by CDK, ingestion, or Lambda env).

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────

# Base URL of the deployed API Gateway HTTP API
# Example: https://abc123.execute-api.us-east-1.amazonaws.com/dev
NEXT_PUBLIC_API_URL=http://localhost:3001

# Cognito User Pool ID (us-east-1_xxxxxxxxx)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito App Client ID (no client secret — SPA client)
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Backend Lambda (set via CDK environment / SSM) ──────────────────────────
# These are NOT needed in .env.local — they are injected by CDK at deploy time.
# Listed here for documentation purposes.

# HMAC secret for signing share tokens. Must be a long random string.
# Generate with: openssl rand -hex 32
SHARE_TOKEN_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public frontend URL used when constructing share links
FRONTEND_URL=https://app.daggerheart.example.com

# DynamoDB table names (injected by CDK)
# CHARACTERS_TABLE=daggerheart-characters-dev
# CLASSES_TABLE=daggerheart-classes-dev
# GAMEDATA_TABLE=daggerheart-gamedata-dev
# DOMAINCARDS_TABLE=daggerheart-domaincards-dev
# MEDIA_TABLE=daggerheart-media-dev
# USERS_TABLE=daggerheart-users-dev

# S3 media bucket name (injected by CDK)
# S3_MEDIA_BUCKET=daggerheart-media-dev-xxxxxxxxx

# CloudFront CDN domain for media URLs (injected by CDK)
# CDN_DOMAIN=dxxxxxxxxxxxxxx.cloudfront.net

# ─── Ingestion Pipeline ───────────────────────────────────────────────────────
# AWS credentials for local ingestion runs.
# In CI/CD these come from the IAM role attached to the runner.

AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Target DynamoDB tables for ingestion (can override per-run with CLI flags)
# INGEST_CLASSES_TABLE=daggerheart-classes-dev
# INGEST_GAMEDATA_TABLE=daggerheart-gamedata-dev
# INGEST_DOMAINCARDS_TABLE=daggerheart-domaincards-dev

# ─── CDK Bootstrap ────────────────────────────────────────────────────────────
# AWS account and region used for CDK deployments.
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1

# Deployment stage: dev | staging | prod
STAGE=dev
