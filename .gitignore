# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── TypeScript build output ─────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ─── AWS CDK ─────────────────────────────────────────────────────────────────
cdk.out/
cdk.context.json
# Synthesised CloudFormation templates (regenerated by cdk synth)
infrastructure/cloudformation/

# ─── Environment & secrets ───────────────────────────────────────────────────
# Keep only the example/template files; ignore everything that may hold real values.
.env
.env.*
*.env
!.env.example
!*.env.example
!*.env.local.example

# Named env files used by ingestion and other tooling
.env.ingestion
*.env.ingestion

# Catch-all patterns for files named with "secret" or "credential" anywhere
*secret*
*credential*
*secrets*
*credentials*
# Exception: utility scripts that generate secrets but contain none themselves
!scripts/ssm-put-secret.mjs

# CDK outputs contain account IDs, ARNs, and endpoint URLs — never commit
infrastructure/cdk-outputs.json

# ─── Test coverage ───────────────────────────────────────────────────────────
coverage/

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
