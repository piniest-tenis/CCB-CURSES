# infrastructure/.env.example
# Copy to infrastructure/.env and fill in real values before running cdk deploy.
# See: Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID

GOOGLE_CLIENT_ID_PROD=your-prod-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_PROD=GOCSPX-your-prod-secret

GOOGLE_CLIENT_ID_DEV=your-dev-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_DEV=GOCSPX-your-dev-secret

# ─── Patreon OAuth ────────────────────────────────────────────────────────────
# Create a Patreon OAuth client at: https://www.patreon.com/portal/registration/register-clients
PATREON_CLIENT_ID=your-patreon-client-id
PATREON_CLIENT_SECRET=your-patreon-client-secret
# Must match the registered redirect URI on Patreon's developer portal
PATREON_REDIRECT_URI=https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com/dev/users/me/patreon/callback
# Numeric campaign ID from your Patreon campaign URL
PATREON_CAMPAIGN_ID=123456
# Creator access token — used to query campaign members endpoint (can see free followers)
PATREON_CREATOR_ACCESS_TOKEN=your-creator-access-token
# ISO 8601 cutoff: accounts created before this are grandfathered (no Patreon required)
PATREON_GATE_CUTOFF_DATE=2026-04-05T00:00:00.000Z
# Public frontend URL for redirect after OAuth callback
FRONTEND_URL=https://ccb.curses.show
