# infrastructure/.env.example
# Copy to infrastructure/.env and fill in real values before running cdk deploy.
# See: Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID

GOOGLE_CLIENT_ID_PROD=your-prod-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_PROD=GOCSPX-your-prod-secret

GOOGLE_CLIENT_ID_DEV=your-dev-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_DEV=GOCSPX-your-dev-secret
