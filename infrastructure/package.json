    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "aws-cdk": "^2.150.0",
    "ts-node": "^10.9.2",
    "source-map-support": "^0.5.21"
  }
}
