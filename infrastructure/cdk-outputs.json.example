{
  "_comment": "This file documents the shape of cdk-outputs.json which is generated by `cdk deploy`.",
  "_comment2": "The real cdk-outputs.json is gitignored because it contains account IDs and endpoint URLs.",
  "_comment3": "After running `cdk deploy`, copy the output values to your .env / frontend/.env.local.",
  "DaggerheartAuth-dev": {
    "UserPoolIdOutput": "us-east-2_XXXXXXXXX",
    "UserPoolClientIdOutput": "xxxxxxxxxxxxxxxxxxxxxxxxxx",
    "CognitoIssuerUrl": "https://cognito-idp.us-east-2.amazonaws.com/us-east-2_XXXXXXXXX",
    "UserPoolArnOutput": "arn:aws:cognito-idp:us-east-2:XXXXXXXXXXXX:userpool/us-east-2_XXXXXXXXX"
  },
  "DaggerheartData-dev": {
    "CharactersTableName": "daggerheart-characters-dev",
    "ClassesTableName": "daggerheart-classes-dev",
    "DomainCardsTableName": "daggerheart-domaincards-dev",
    "GameDataTableName": "daggerheart-gamedata-dev",
    "MediaTableName": "daggerheart-media-dev",
    "UsersTableName": "daggerheart-users-dev"
  },
  "DaggerheartStorage-dev": {
    "MediaBucketName": "daggerheart-media-dev-XXXXXXXXXXXX",
    "CdnDistributionId": "XXXXXXXXXXXXX",
    "CdnDomainName": "dxxxxxxxxxxxxxx.cloudfront.net"
  },
  "DaggerheartApi-dev": {
    "ApiUrl": "https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com/dev",
    "ApiId": "xxxxxxxxxx"
  },
  "DaggerheartFrontend-dev": {
    "FrontendBucketName": "daggerheart-frontend-dev-XXXXXXXXXXXX",
    "FrontendDistributionId": "XXXXXXXXXXXXX",
    "FrontendDomainName": "dxxxxxxxxxxxxxx.cloudfront.net"
  }
}
