# Curses! CMS — Local Environment Variables
#
# Copy this file to cms/.env.local for local CMS development.
# NEVER commit cms/.env.local — it is covered by the root .gitignore.
#
# See the root .env.example for all shared / backend variables.

# Base URL of the deployed API Gateway HTTP API
# Example: https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com/dev
NEXT_PUBLIC_API_URL=http://localhost:3001

# Cognito — Google SSO for CMS admin access.
NEXT_PUBLIC_COGNITO_REGION=us-east-2

# The CMS-specific Cognito app client (PKCE, no secret)
NEXT_PUBLIC_COGNITO_CMS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI domain  (format: <pool-name>.auth.<region>.amazoncognito.com)
NEXT_PUBLIC_COGNITO_HOSTED_DOMAIN=curses-ccb-dev.auth.us-east-2.amazoncognito.com
